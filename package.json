{
  "name": "chrono-station",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "user:create": "npm run user:create --workspace server --",
    "db:up": "docker compose -f docker-compose.dev.yml up -d db",
    "db:migrate": "docker compose -f docker-compose.dev.yml run --rm migrate",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace client"
  }
}
