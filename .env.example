# Tag immagine da deployare. La CI lo imposta allo SHA del commit; default 'latest'.
TAG=latest

# Credenziali PostgreSQL (servizio `db` in docker-compose.yml). Da impostare in prod.
# Il server e il container di migrazione Liquibase le compongono in DATABASE_URL / JDBC URL.
POSTGRES_USER=chrono
POSTGRES_PASSWORD=chrono
POSTGRES_DB=chrono

# Indirizzo del sito per Caddy.
#   :80                  -> solo HTTP
#   chrono.example.com   -> HTTPS automatico (certificati Let's Encrypt)
SITE_ADDRESS=:80
